{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "2.0.0",
    "inputs": [
        {
            "id": "pick-exe",
            "type": "command",
            "command": "extension.commandvariable.file.pickFile", // install this 
            "args": {
                "include": "**/*.{exe}",
            }
        },
        {
            "id": "debug.target",
            "type": "command",
            "command": "extension.commandvariable.pickStringRemember",
            "args": {
                "key": "target",
                // "desc": "Input the target name to debug(xmake l targets)",
                "addLabelToTop": "${remeber.target}",
                "options": [
                    "HelloMaterial",
                    {
                        "label": "Other...",
                        "description": "Input the target name to debug(xmake l targets)",
                        "value": "${promptStringRemember:customTarget}"
                    }
                ],
                "promptStringRemember": {
                    "customTarget": {
                        "key": "target",
                        "description": "Enter build target name:"
                    }
                }
            }
        },
    ],
    "configurations": [
        {
            "type": "cppvsdbg",
            "request": "attach",
            "name": "Attach EXE",
            "processId": "${command:pickProcess}"
        },
        {
            "type": "cppvsdbg",
            "name": "debug EXE MSVC",
            "request": "launch",
            "program": "${input:pick-exe}",
            "logging": {
                "moduleLoad": true,
                "threadExit": true,
                "processExit": true,
                "programOutput": true,
                "engineLogging": false,
                "exceptions": true
            },
            "cwd": "${workspaceRoot}",
            "console": "integratedTerminal",
            "visualizerFile": "${workspaceFolder}/.vscode/all.natvis",
            // "justMyCode": true,
            // "preLaunchTask": "xmake build",
        },
        {
            "type": "cppvsdbg",
            "name": "debug EXE MSVC with build",
            "request": "launch",
            "program": "${workspaceFolder}/build/windows/x64/debug/${input:debug.target}.exe",
            "logging": {
                "moduleLoad": true,
                "threadExit": true,
                "processExit": true,
                "programOutput": true,
                "engineLogging": false,
                "exceptions": true
            },
            "cwd": "${workspaceRoot}",
            "console": "integratedTerminal",
            "visualizerFile": "${workspaceFolder}/.vscode/all.natvis",
            // "justMyCode": true,
            "preLaunchTask": "xmake build",
            "requireExactSource": false,
        },
    ]
}